{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/packages/cspell-types/cspell.schema.json",
  "version": "0.2",
  "language": "en,ja",
  "ignorePaths": [
    "vendor/**",
    "bin/**",
    "*.sum",
    "node_modules/**"
  ],
  "words": [
    "BUILDPLATFORM",
    "TARGETARCH",
    "TARGETOS",
    "bcrypt",
    "bodyclose",
    "buildx",
    "cloudflared",
    "clusterip",
    "configmap",
    "entrypoints",
    "envsubst",
    "errcheck",
    "fieldref",
    "ghcr",
    "ginctx",
    "gocritic",
    "godotenv",
    "gofmt",
    "gofumpt",
    "goimports",
    "golangci",
    "gosimple",
    "govet",
    "httptest",
    "ineffassign",
    "ingress",
    "kazuma",
    "kazumadev",
    "kubeconfig",
    "kubectl",
    "ldflags",
    "livenessProbe",
    "middlewares",
    "multiarch",
    "namespace",
    "nilerr",
    "noctx",
    "nosawakazuma",
    "openweather",
    "openweathermap",
    "pathtype",
    "pgsql",
    "pgx",
    "postgres",
    "postgresql",
    "pullpolicy",
    "readinessProbe",
    "resend",
    "secretkeyref",
    "sqlc",
    "sqlcgen",
    "statefulset",
    "stringdata",
    "stripprefix",
    "traefik",
    "txdb",
    "usecase",
    "usecases",
    "valueFrom",
    "websecure",
    "wrapcheck"
  ],
  "overrides": [
    {
      "filename": "**/*.go",
      "words": [
        "struct",
        "func",
        "chan",
        "goroutine",
        "goroutines",
        "pkgerrors"
      ]
    }
  ]
}
