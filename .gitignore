# .gitignore

# -----------------------------------------------
# Go
# -----------------------------------------------
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
vendor/

# -----------------------------------------------
# 環境変数・シークレット
# -----------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------
# k8s シークレット実値ファイル（テンプレートはGit管理対象）
# -----------------------------------------------
k8s/config/*.yaml.local

# -----------------------------------------------
# Raspberry Pi DB 設定（本番シークレット）
# -----------------------------------------------
.env.db

# -----------------------------------------------
# ビルド成果物
# -----------------------------------------------
dist/
build/

# -----------------------------------------------
# IDE / エディタ
# -----------------------------------------------
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# -----------------------------------------------
# テスト・カバレッジ
# -----------------------------------------------
coverage.out
coverage.html

# -----------------------------------------------
# kubeconfig ローカルコピー
# -----------------------------------------------
kubeconfig.yaml
kubeconfig*.yaml

# -----------------------------------------------
# Git worktrees
# -----------------------------------------------
.worktrees/
